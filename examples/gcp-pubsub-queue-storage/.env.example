# Keystore passphrase used to decrypt config/keys/local-signer.json
KEYSTORE_PASSPHRASE=
# API key clients present as `Authorization: Bearer <API_KEY>`
API_KEY=
# Signing key for outbound webhook notifications
WEBHOOK_SIGNING_KEY=

# --- Real GCP only (docker-compose.gcp.yaml); ignored by the emulator compose ---
# GCP project that holds the Pub/Sub topics/subscriptions
PUBSUB_PROJECT_ID=
# Optional: host path to the credentials file mounted into the container.
# Defaults to config/keys/gcp-sa-key.json (a service-account key). Override to use
# your gcloud ADC instead, e.g.:
#   GCP_CREDENTIALS_FILE=/Users/me/.config/gcloud/application_default_credentials.json
# GCP_CREDENTIALS_FILE=
