# Copy to `.env` and fill in. The keystore in config/keys/local-signer.json was
# generated with the passphrase below — change both together if you regenerate it
# (cargo run --example create_key -- --password <pw> --output-dir config/keys --filename local-signer.json --force).

# API key clients use as `Authorization: Bearer <API_KEY>` (must be >= 32 characters).
API_KEY=multi-threaded-runtime-example-api-key

# Passphrase for config/keys/local-signer.json (matches the committed test keystore).
KEYSTORE_PASSPHRASE=MultiThread123!

# Webhook HMAC signing key (unused here; notifications point at an empty URL).
WEBHOOK_SIGNING_KEY=example-webhook-signing-key

# Pipeline + HTTP worker sizing. Keep ACTIX_WORKERS + TOKIO_WORKER_THREADS <= container CPUs.
TOKIO_WORKER_THREADS=4
ACTIX_WORKERS=2

# Set to debug for more per-stage pipeline logs during the distribution check.
LOG_LEVEL=info
